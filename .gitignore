# ═══════════════════════════════════════════════════════════════════
#  7z Project Suite — .gitignore
#  Covers: C++ (CMake/Make), Python, all OSes
# ═══════════════════════════════════════════════════════════════════

# ── Build directories ────────────────────────────────────────────
build/
cmake-build-*/
out/
_build/

# ── C / C++ compiled objects ─────────────────────────────────────
*.o
*.obj
*.lo
*.slo
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.dSYM/

# ── Precompiled headers ──────────────────────────────────────────
*.gch
*.pch

# ── CMake ────────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CTestTestfile.cmake
_deps/
CMakeUserPresets.json
compile_commands.json
install_manifest.txt
*_autogen/

# ── Qt ───────────────────────────────────────────────────────────
moc_*.cpp
ui_*.h
qrc_*.cpp
*.moc

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg
*.egg-info/
dist/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/

# ── macOS ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ── Windows ──────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Linux ────────────────────────────────────────────────────────
*~
.directory

# ── IDEs and editors ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.kate-swp
.project
.cproject
.settings/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ── Testing / coverage ──────────────────────────────────────────
*.gcov
*.gcda
*.gcno
htmlcov/
.coverage
.tox/
.pytest_cache/

# ── Project-specific ─────────────────────────────────────────────
# Test data (large, generated)
**/testdata/

# Tree cache files (generated by 7z-fm)
*.7z.tree

# Large report files
report-blocks.txt
report-files.txt

# Benchmark temp archives
*.7z.tmp

# Compiled binaries
7z-info/7z-info
7z-benchmark/7z-bench
